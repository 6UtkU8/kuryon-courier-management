{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=KuryonDb;User Id=YOUR_DB_USER;Password=YOUR_STRONG_DB_PASSWORD;TrustServerCertificate=False;MultipleActiveResultSets=True"
  },
  "Jwt": {
    "Key": "SET_FROM_ENVIRONMENT_OR_SECRET_MANAGER_MIN_32_CHARS_REPLACE_ME",
    "Issuer": "https://api.your-domain.com",
    "Audience": "https://panel.your-domain.com",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "https://panel.your-domain.com"
    ]
  },
  "Features": {
    "EnableSwagger": false,
    "EnableTestEndpoints": false,
    "EnableDevelopmentSeedData": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Error"
    }
  },
  "AllowedHosts": "*"
}
