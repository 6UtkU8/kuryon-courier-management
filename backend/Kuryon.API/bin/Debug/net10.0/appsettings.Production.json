{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=KuryonDb;User Id=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Jwt": {
    "Key": "SET_FROM_ENVIRONMENT_OR_SECRET_MANAGER_MIN_32_CHARS",
    "Issuer": "Kuryon.API",
    "Audience": "Kuryon.Client",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "https://admin.your-domain.com"
    ]
  },
  "Features": {
    "EnableSwagger": false,
    "EnableTestEndpoints": false,
    "EnableDevelopmentSeedData": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Error"
    }
  }
}
